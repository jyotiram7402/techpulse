# ===================================================================
# Supabase (REQUIRED) — create a free project at https://supabase.com
# ===================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================================================================
# Cron security — any random long string. Vercel cron jobs send this
# as a Bearer token in the Authorization header.
# ===================================================================
CRON_SECRET=replace-with-a-long-random-string

# ===================================================================
# Hugging Face Inference API (OPTIONAL — falls back to rule-based
# summarization if absent). Free tier token from https://huggingface.co/settings/tokens
# ===================================================================
HUGGINGFACE_API_KEY=

# ===================================================================
# Site URL (used for SEO metadata, OG, sitemap)
# ===================================================================
NEXT_PUBLIC_SITE_URL=https://your-deployment.vercel.app
